---
// Languages — reversed split with source/target matrix.
---

<section class="section" id="langs" style="padding-top:0;">
  <div class="wrap split rev">
    <div class="split-copy reveal">
      <span class="eyebrow" data-i18n="lang_eyebrow">Idiomas</span>
      <h2 class="h-sec" style="margin-top:16px;" data-i18n="lang_title">Español, inglés e italiano — en ambos sentidos.</h2>
      <p class="lead" style="margin-top:16px;" data-i18n="lang_sub">Cada idioma funciona como origen y como destino de la voz. Mezclá como quieras.</p>
      <div class="lang-soon" style="margin-top:22px;">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><path d="M12 7.5V12l3 2" /></svg>
        <span data-i18n="lang_soon">Portugués, francés y alemán en camino</span>
      </div>
    </div>
    <div class="split-media reveal">
      <div class="card card-pad">
        <div class="lang-matrix">
          <div class="lang-row" style="border-bottom:1px solid var(--line);padding-top:0;">
            <span class="lang-flag">🇪🇸</span>
            <div style="flex:1;"><span class="lang-name">Español</span> <span class="lang-native">· Español</span></div>
            <div class="lang-tags"><span class="tag src" data-i18n="tag_src">Origen</span><span class="tag tgt" data-i18n="tag_tgt">Destino</span></div>
          </div>
          <div class="lang-row" style="border-bottom:1px solid var(--line);">
            <span class="lang-flag">🇬🇧</span>
            <div style="flex:1;"><span class="lang-name">Inglés</span> <span class="lang-native">· English</span></div>
            <div class="lang-tags"><span class="tag src" data-i18n="tag_src">Origen</span><span class="tag tgt" data-i18n="tag_tgt">Destino</span></div>
          </div>
          <div class="lang-row" style="padding-bottom:0;">
            <span class="lang-flag">🇮🇹</span>
            <div style="flex:1;"><span class="lang-name">Italiano</span> <span class="lang-native">· Italiano</span></div>
            <div class="lang-tags"><span class="tag src" data-i18n="tag_src">Origen</span><span class="tag tgt" data-i18n="tag_tgt">Destino</span></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
