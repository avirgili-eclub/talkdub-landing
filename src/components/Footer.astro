---
// Footer — brand, link columns and socials.
---

<footer class="footer">
  <div class="wrap">
    <div class="footer-top">
      <div class="footer-brand">
        <a class="brand" href="#top">
          <img class="logo" src="/brand/talkdub-icon.svg" alt="" aria-hidden="true" />
          <span class="name">Talkdub</span>
        </a>
        <p data-i18n="foot_tag">Traducción de voz en tiempo real, con tu propia voz. Por Veinticuatro7 Studio.</p>
      </div>
      <div class="footer-cols">
        <div class="footer-col">
          <h4 data-i18n="foot_product">Producto</h4>
          <a href="#how" data-i18n="fl_how">Cómo funciona</a>
          <a href="#pricing" data-i18n="fl_pricing">Precios</a>
          <a href="#voice" data-i18n="fl_voice">Clon de voz</a>
          <a href="#langs" data-i18n="fl_langs">Idiomas</a>
        </div>
        <div class="footer-col">
          <h4 data-i18n="foot_resources">Recursos</h4>
          <a href="#" data-i18n="fl_docs">Documentación</a>
          <a href="#history" data-i18n="fl_mcp">MCP & API</a>
          <a href="#" data-i18n="fl_status">Estado</a>
          <a href="#" data-i18n="fl_changelog">Novedades</a>
        </div>
        <div class="footer-col">
          <h4 data-i18n="foot_company">Empresa</h4>
          <a href="#" data-i18n="fl_about">Nosotros</a>
          <a href="#" data-i18n="fl_privacy">Privacidad</a>
          <a href="#" data-i18n="fl_terms">Términos</a>
          <a href="#" data-i18n="fl_contact">Contacto</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <span data-i18n="foot_rights">© 2026 Veinticuatro7 Studio. Todos los derechos reservados.</span>
      <div class="soc">
