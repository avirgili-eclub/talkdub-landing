---
// Fullscreen mobile menu. Open/close handled in app.js via #burger / [data-close-menu].
---

<div class="m-sheet" id="m-sheet">
  <div class="wrap m-top" style="padding:0;">
    <a class="brand" href="#top" data-close-menu>
      <img class="logo" src="/brand/talkdub-icon.svg" alt="" aria-hidden="true" />
      <span class="name">Talkdub</span>
    </a>
    <button class="m-close" id="m-close" aria-label="Cerrar">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6 6 18" /></svg>
    </button>
  </div>
  <nav>
    <a href="#how" data-close-menu data-i18n="nav_how">Cómo funciona</a>
    <a href="#uses" data-close-menu data-i18n="nav_uses">Casos de uso</a>
    <a href="#voice" data-close-menu data-i18n="nav_voice">Tu voz</a>
    <a href="#langs" data-close-menu data-i18n="nav_langs">Idiomas</a>
    <a href="#pricing" data-close-menu data-i18n="nav_pricing">Precios</a>
  </nav>
  <div class="m-cta">
    <div class="lang" style="align-self:flex-start;">
      <button data-lang-btn="es" class="on">ES</button>
      <button data-lang-btn="en">EN</button>
    </div>
    <a href="#join" class="btn btn-primary btn-lg btn-block" data-close-menu data-i18n="cta_whitelist">Unirse a la whitelist</a>
  </div>
</div>
