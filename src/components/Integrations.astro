---
// "Works where you already work" — integration chips row.
---

<section class="section integ" style="padding-top:0;">
  <div class="wrap">
    <p class="integ-cap reveal" data-i18n="integ_cap">Funciona donde ya trabajás</p>
    <div class="integ-row reveal" data-stagger>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><rect x="2" y="5" width="14" height="14" rx="4" fill="#5b5fc7" /><circle cx="18" cy="8" r="3.4" fill="#7b7fdb" /><path d="M6 9.2h6M9 9.2V15" stroke="#fff" stroke-width="1.7" stroke-linecap="round" /></svg>
        Microsoft Teams
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><rect x="3" y="6.5" width="12" height="11" rx="2.6" fill="#00ac47" /><path d="M15 10.2l5.2-2.8a.8.8 0 0 1 1.2.7v7.8a.8.8 0 0 1-1.2.7L15 13.8z" fill="#00832d" /><path d="M3 9.1A2.6 2.6 0 0 1 5.6 6.5H9L3 12z" fill="#fbbc04" /><path d="M3 15a2.6 2.6 0 0 0 2.6 2.5h2.2L3 12z" fill="#ea4335" /><path d="M15 6.5h-3.4L15 10z" fill="#4285f4" /></svg>
        Google Meet
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><rect x="2.5" y="6.5" width="12" height="11" rx="3" fill="#4a8cff" /><path d="M14.5 10.4l4.6-2.6a.8.8 0 0 1 1.2.7v6.8a.8.8 0 0 1-1.2.7l-4.6-2.6z" fill="#4a8cff" /></svg>
        Zoom
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><rect width="24" height="24" rx="6" fill="#5865f2" /><ellipse cx="9.2" cy="13" rx="1.5" ry="1.9" fill="#fff" /><ellipse cx="14.8" cy="13" rx="1.5" ry="1.9" fill="#fff" /><path d="M7 8.6c3.3-1.5 6.7-1.5 10 0M7.6 16.4c2.8 1.3 6 1.3 8.8 0" stroke="#fff" stroke-width="1.5" stroke-linecap="round" /></svg>
        Discord
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><rect x="10" y="2.5" width="4" height="9" rx="2" fill="#36C5F0" /><rect x="12.5" y="10" width="9" height="4" rx="2" fill="#2EB67D" /><rect x="10" y="12.5" width="4" height="9" rx="2" fill="#ECB22E" /><rect x="2.5" y="10" width="9" height="4" rx="2" fill="#E01E5A" /></svg>
        Slack
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="9.5" fill="#1e1c27" /><circle cx="12" cy="12" r="9.5" stroke="#fff" stroke-width="1.3" opacity=".5" /><circle cx="12" cy="12" r="4" fill="none" stroke="#fff" stroke-width="1.6" /><path d="M12 12a6.6 6.6 0 0 1 5.4-2.3" stroke="#fff" stroke-width="1.6" stroke-linecap="round" fill="none" /></svg>
        OBS Studio
      </span>
      <span class="integ-chip">
        <svg viewBox="0 0 24 24" fill="none" stroke="#a3b1c9" stroke-width="1.7"><circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" stroke-linecap="round" /></svg>
        <span data-i18n="integ_web">Navegador web</span>
      </span>
      <span class="integ-chip more" data-i18n="integ_more">y cualquier app con micrófono</span>
    </div>
  </div>
</section>
