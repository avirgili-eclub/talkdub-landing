---
// Fixed top navigation. The .scrolled state and burger toggle are wired in app.js.
---

<header class="nav" id="nav">
  <div class="wrap nav-inner">
    <a class="brand" href="#top" aria-label="Parla">
      <svg class="logo" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="9" fill="url(#plg)" />
        <g stroke="#021510" stroke-width="2.4" stroke-linecap="round">
          <path d="M9 11v10" /><path d="M14 8v16" /><path d="M19 12.5v7" /><path d="M24 14.5v3" />
        </g>
        <defs><linearGradient id="plg" x1="0" y1="0" x2="32" y2="32">
          <stop stop-color="#34d3ee" /><stop offset="1" stop-color="#3ee0a0" /></linearGradient></defs>
      </svg>
      <span class="name">Parla</span>
    </a>
    <nav class="nav-links">
      <a href="#how" data-i18n="nav_how">Cómo funciona</a>
      <a href="#uses" data-i18n="nav_uses">Casos de uso</a>
      <a href="#voice" data-i18n="nav_voice">Tu voz</a>
      <a href="#langs" data-i18n="nav_langs">Idiomas</a>
      <a href="#pricing" data-i18n="nav_pricing">Precios</a>
    </nav>
    <div class="nav-right">
      <div class="lang" role="group" aria-label="Idioma">
        <button data-lang-btn="es" class="on">ES</button>
        <button data-lang-btn="en">EN</button>
      </div>
      <a href="#join" class="btn btn-secondary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 4v11M7.5 11 12 15.5 16.5 11" /><path d="M5 19.5h14" /></svg>
        <span data-i18n="os_avail">Para Windows y macOS</span>
      </a>
      <a href="#join" class="btn btn-primary" data-i18n="cta_whitelist">Unirse a la whitelist</a>
      <button class="burger" id="burger" aria-label="Menú">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
    </div>
  </div>
</header>
