---
// Hero: headline + live translation console (waveform canvas + typing demo in app.js).
---

<section class="section hero">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <span class="eyebrow"><span class="live-dot-wrap"></span>
        <svg class="glyph" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round"><path d="M3 12h2M7.5 8v8M12 4v16M16.5 8v8M21 12h-2" /></svg>
        <span data-i18n="hero_badge">En vivo · Latencia &lt; 200 ms</span>
      </span>
      <h1 style="margin-top:22px;">
        <span data-i18n="hero_title_a">Hablá en tu idioma.</span><br />
        <span class="grad-text" data-i18n="hero_title_b">Que te escuchen en el suyo.</span>
      </h1>
      <p class="lead" data-i18n="hero_sub">Traducción de voz en tiempo real. Tu voz sale traducida por un micrófono virtual hacia Meet, Zoom, Teams, Discord, Slack y cualquier app donde haya un micrófono.</p>
      <div class="hero-cta">
        <a href="#join" class="btn btn-primary btn-lg" data-i18n="cta_whitelist">Unirse a la whitelist</a>
        <a href="#how" class="btn btn-secondary btn-lg">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"><path d="M7 5l12 7-12 7z" fill="currentColor" stroke="none" /></svg>
          <span data-i18n="hero_demo">Ver demo</span>
        </a>
      </div>
      <div class="hero-meta">
        <span class="it"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.5 10 17 19 7" /></svg><span data-i18n="hero_m1">Sin delay incómodo</span></span>
        <span class="it"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8.5" r="3.8" /><path d="M5 20c.8-3.6 3.5-5.5 7-5.5s6.2 1.9 7 5.5" /></svg><span data-i18n="hero_m2">Con tu propia voz</span></span>
        <span class="it"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18" /></svg><span data-i18n="hero_m3">ES · EN · IT</span></span>
        <span class="it os-row"><svg viewBox="0 0 24 24" fill="none"><path d="M3 5.7 10 4.7v6.6H3zM10.8 4.6 21 3.2v8H10.8zM3 12.7h7v6.6l-7-1zM10.8 12.7H21v8l-10.2-1.4z" fill="#a3b1c9"/></svg><svg viewBox="0 0 24 24" fill="#a3b1c9"><path d="M16 3.2c.1 1-.3 2-1 2.8-.7.8-1.7 1.4-2.7 1.3-.1-1 .4-2 1-2.7.8-.8 1.9-1.4 2.7-1.4zM18.6 17c-.5 1.1-.7 1.6-1.3 2.6-.9 1.4-2.1 3.1-3.6 3.1-1.3 0-1.7-.8-3.4-.8s-2.2.8-3.4.9c-1.5 0-2.6-1.5-3.5-2.9-2.4-3.8-2.7-8.2-1.2-10.6 1-1.7 2.7-2.7 4.3-2.7 1.6 0 2.6.9 3.9.9 1.3 0 2-.9 3.9-.9 1.4 0 2.9.8 3.9 2.1-3.4 1.9-2.9 6.8.9 8.3z"/></svg><span data-i18n="os_avail">Para Windows y macOS</span></span>
      </div>
    </div>

    <!-- Live translation console -->
    <div class="hero-visual" style="position:relative;">
      <div class="float-chip tl">
        <svg viewBox="0 0 24 24" fill="none" stroke="#3ee0a0" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8.5" r="3.8" /><path d="M5 20c.8-3.6 3.5-5.5 7-5.5s6.2 1.9 7 5.5" /></svg>
        <span data-i18n="chip_voice">Tu voz clonada</span>
      </div>
      <div class="float-chip br">
        <span class="live-pill" style="border:none;background:none;padding:0;backdrop-filter:none;"><span class="dot beat"></span></span>
        <span data-i18n="chip_live">En vivo</span>
      </div>

      <div class="console">
        <div class="console-top">
          <div class="traffic"><i class="r"></i><i class="y"></i><i class="g"></i></div>
          <span class="title" data-i18n="con_title">Parla · Sesión en vivo</span>
        </div>

        <div class="lane in">
          <span class="flag">🇪🇸</span>
          <div class="lane-meta">
            <div class="lane-lbl" data-i18n="con_in">Entrada · Español</div>
            <div class="lane-txt" id="lane-in">Hola, gracias por venir hoy.</div>
          </div>
        </div>

        <div class="conv-row">
          <span class="conv-line"></span>
          <span class="conv-node">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M4 8h13l-3.5-3.5M20 16H7l3.5 3.5" /></svg>
            <span data-i18n="con_conv">Traduciendo en vivo</span>
          </span>
          <span class="conv-line"></span>
        </div>

        <div class="lane out">
          <span class="flag">🇬🇧</span>
          <div class="lane-meta">
            <div class="lane-lbl" data-i18n="con_out">Salida · Inglés</div>
            <div class="lane-txt" id="lane-out">Hi, thanks for joining today.</div>
          </div>
        </div>

        <div class="wave-canvas-wrap">
          <canvas id="hero-wave" aria-hidden="true"></canvas>
        </div>

        <div class="console-foot">
          <span class="vmic">
            <span class="ic"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M7 3v4M11 3v4" /><path d="M5 7h8v3a4 4 0 0 1-4 4 4 4 0 0 1-4-4z" /><path d="M9 14v3a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3v-3" /><path d="M17 14h2" /></svg></span>
            <span data-i18n="con_vmic">Micrófono virtual de Parla</span>
          </span>
          <span class="lat"><b data-count="180" data-suffix=" ms">180 ms</b> <span data-i18n="con_lat">latencia</span></span>
        </div>
      </div>
    </div>
  </div>
</section>
